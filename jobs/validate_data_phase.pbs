#!/bin/bash
#PBS -N peak-cot-validate
#PBS -l select=1:ncpus=1:mem=4gb
#PBS -l walltime=00:20:00
#PBS -j oe
#PBS -V
#PBS -o /srv/scratch/${USER}/peak-CoT/validate_data_phase.pbs.log

set -euo pipefail

PROJECT_NAME="peak-CoT"
: "${PROJECT_HOME:=/home/${USER}/${PROJECT_NAME}}"
: "${CONFIG_PATH:=configs/stage1.yaml}"
: "${CANONICAL_RUN_NAME:=full_generation}"

cd "${PROJECT_HOME}" || exit 1
if [[ ! -f "${PROJECT_HOME}/.env" ]]; then
  echo "missing .env at ${PROJECT_HOME}/.env"
  exit 1
fi

set +u
set -a
source "${PROJECT_HOME}/.env"
set +a
set -u

: "${SCRATCH:?SCRATCH must be set by ${PROJECT_HOME}/.env}"

RUN_DIR="${SCRATCH}/runs/${CANONICAL_RUN_NAME}"
LOG_PATH="${RUN_DIR}/logs/data-phase-validate.log"

mkdir -p "${RUN_DIR}/logs"
exec > >(tee -a "${LOG_PATH}") 2>&1

echo "project_home=${PROJECT_HOME}"
echo "scratch_root=${SCRATCH}"
echo "run_dir=${RUN_DIR}"
echo "config_path=${CONFIG_PATH}"

python scripts/validate.py \
  --canonical-run-dir "${RUN_DIR}" \
  --config "${CONFIG_PATH}" \
  --json
